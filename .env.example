# ─── Marzoq.com Environment Variables ───────────────────────────────────────
# Copy this file to .env for local development.
# In production (Netlify / Vercel), set these in the platform dashboard.
# Never commit the actual .env file — it is gitignored.

# ─── Required ─────────────────────────────────────────────────────────────────

# Production site URL (no trailing slash)
# Used for: canonical URLs, Open Graph og:url, sitemap.xml <loc> entries
# Example: https://mrzoq.com
SITE_URL=https://mrzoq.com

# ─── Optional: Headless CMS ────────────────────────────────────────────────────

# WordPress REST API base URL (no trailing slash)
# Used for: fetching posts, portfolio items, services at build time
# When unset: all CMS-dependent pages build with empty states (graceful)
# Example: https://blog.mrzoq.com
WORDPRESS_URL=https://blog.mrzoq.com

# ─── Notes ───────────────────────────────────────────────────────────────────
# - WORDPRESS_URL must be accessible from the CI/CD build environment
# - If WORDPRESS_URL is blocked by firewall, CMS pages will show empty state
# - Blog and portfolio dynamic routes (/blog/[slug], /portfolio/[slug]) require
#   WORDPRESS_URL to generate static pages at build time
