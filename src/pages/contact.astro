---
/**
 * Contact — Marzoq
 *
 * Experience Page: single viewport, no scrolling.
 * Remove hesitation. Make starting a conversation feel simple and immediate.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import GlassPanel from '../components/GlassPanel.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="تواصل معنا — مرزوق"
  description="ابدأ محادثة مع مرزوق. نحن هنا للمساعدة في بناء حضورك الرقمي الذي يفهمه الذكاء الاصطناعي."
>
  <div class="page-content contact-page is-locked">
    <div class="layer-background" aria-hidden="true">
      <div class="background__grid"></div>
    </div>

    <Header currentPath="/contact" />

    <main class="contact__content" id="main-content">
      <div class="contact__body">
        <!-- Right Column (Info) -->
        <div class="contact__col contact__col--right">
          <div class="contact__headline-block">
            <h1 class="contact__headline">ابدأ محادثة</h1>
            <p class="contact__subtext">
              نحن هنا للإجابة على أسئلتك ومساعدتك في فهم كيف يمكن لمرزوق مساعدة شركتك.
            </p>
            
            <div class="contact__info">
              <div class="contact__info-item">
                <div class="contact__info-header">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                  <span class="contact__info-label">البريد الإلكتروني</span>
                </div>
                <a href="mailto:hello@marzoq.com" class="contact__info-link">hello@marzoq.com</a>
              </div>
              <div class="contact__info-item">
                <div class="contact__info-header">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                  <span class="contact__info-label">الهاتف</span>
                </div>
                <a href="tel:+966500000000" class="contact__info-link" dir="ltr">+966 50 000 0000</a>
              </div>
              <div class="contact__info-item">
                <div class="contact__info-header">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
                  <span class="contact__info-label">واتساب</span>
                </div>
                <a href="https://wa.me/966500000000" class="contact__info-link" dir="ltr" target="_blank" rel="noopener noreferrer">+966 50 000 0000</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Left Column (Form) -->
        <div class="contact__col contact__col--left">

        <GlassPanel class="contact__form-panel" padding="lg" radius="xl">
          <!--
            Netlify Forms: data-netlify="true" and name="contact" activate form detection
            at deploy time. Without a Netlify deployment the fallback is native HTML
            submission (action="/contact"). The form-name hidden field is required for
            AJAX submission to Netlify.
          -->
          <form
            class="contact__form"
            name="contact"
            method="POST"
            action="/contact"
            data-netlify="true"
            data-netlify-honeypot="bot-field"
          >
            <input type="hidden" name="form-name" value="contact" />

            <!-- Honeypot — hidden from real users, visible to bots -->
            <div class="contact__honeypot" aria-hidden="true">
              <input name="bot-field" tabindex="-1" autocomplete="off" />
            </div>

            <!-- ARIA live region — announces submission outcome to screen readers -->
            <div class="contact__status" role="status" aria-live="polite" aria-atomic="true"></div>

            <div class="contact__form-row">
              <div class="contact__field">
                <label class="contact__label" for="name">الاسم</label>
                <input
                  class="contact__input"
                  id="name"
                  name="name"
                  type="text"
                  autocomplete="name"
                  required
                  aria-required="true"
                  placeholder="اسمك الكريم"
                />
                <span class="contact__error" id="name-error" role="alert" aria-live="assertive"
                ></span>
              </div>
  
              <div class="contact__field">
                <label class="contact__label" for="email">البريد الإلكتروني</label>
                <input
                  class="contact__input"
                  id="email"
                  name="email"
                  type="email"
                  autocomplete="email"
                  required
                  aria-required="true"
                  placeholder="your@email.com"
                  dir="ltr"
                />
                <span class="contact__error" id="email-error" role="alert" aria-live="assertive"
                ></span>
              </div>
            </div>

            <div class="contact__field">
              <label class="contact__label" for="company">الشركة (اختياري)</label>
              <input
                class="contact__input"
                id="company"
                name="company"
                type="text"
                autocomplete="organization"
                placeholder="اسم شركتك"
              />
            </div>

            <div class="contact__field">
              <label class="contact__label" for="message">رسالتك</label>
              <textarea
                class="contact__input contact__textarea"
                id="message"
                name="message"
                required
                aria-required="true"
                rows="3"
                placeholder="أخبرنا عن شركتك وما تحتاجه..."></textarea>
              <span class="contact__error" id="message-error" role="alert" aria-live="assertive"
              ></span>
            </div>

            <button type="submit" class="contact__submit focus-visible" id="contact-submit">
              إرسال الرسالة
            </button>
          </form>
        </GlassPanel>
        </div>
      </div>
    </main>

    <Footer />
  </div>
</BaseLayout>

<script>
  const form = document.querySelector<HTMLFormElement>('.contact__form');
  const submitBtn = document.querySelector<HTMLButtonElement>('#contact-submit');
  const statusEl = document.querySelector<HTMLElement>('.contact__status');

  if (form && submitBtn && statusEl) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Clear previous status
      statusEl.textContent = '';
      statusEl.className = 'contact__status';

      // Client-side validation
      const valid = validateForm();
      if (!valid) return;

      // Pending state — disable submission
      submitBtn.disabled = true;
      submitBtn.textContent = 'جارٍ الإرسال…';
      statusEl.textContent = 'جارٍ إرسال رسالتك…';
      statusEl.classList.add('contact__status--pending');

      try {
        const data = new FormData(form);
        const encoded = new URLSearchParams(data as unknown as Record<string, string>).toString();

        const res = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: encoded,
        });

        if (res.ok) {
          // Success
          form.reset();
          statusEl.textContent = 'شكرًا! وصلت رسالتك وسنرد عليك قريبًا.';
          statusEl.classList.remove('contact__status--pending');
          statusEl.classList.add('contact__status--success');
          submitBtn.textContent = 'تم الإرسال';
          // Move focus to success message
          statusEl.setAttribute('tabindex', '-1');
          statusEl.focus();
        } else {
          throw new Error(`HTTP ${res.status}`);
        }
      } catch {
        // Failure — preserve values, restore button
        statusEl.textContent =
          'حدث خطأ أثناء الإرسال. يرجى المحاولة مرة أخرى أو التواصل مباشرة عبر البريد الإلكتروني.';
        statusEl.classList.remove('contact__status--pending');
        statusEl.classList.add('contact__status--error');
        submitBtn.disabled = false;
        submitBtn.textContent = 'إرسال الرسالة';
        // Move focus to error message
        statusEl.setAttribute('tabindex', '-1');
        statusEl.focus();
      }
    });

    // Real-time validation on blur
    form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('[required]').forEach((field) => {
      field.addEventListener('blur', () => validateField(field));
      field.addEventListener('input', () => clearFieldError(field));
    });
  }

  function validateForm(): boolean {
    const fields = form!.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('[required]');
    let valid = true;
    fields.forEach((field) => {
      if (!validateField(field)) valid = false;
    });
    if (!valid) {
      // Focus first invalid field
      const first = form!.querySelector<HTMLElement>('[aria-invalid="true"]');
      first?.focus();
    }
    return valid;
  }

  function validateField(field: HTMLInputElement | HTMLTextAreaElement): boolean {
    const errorEl = document.getElementById(`${field.id}-error`);
    if (!errorEl) return true;

    if (!field.validity.valid) {
      let msg = 'هذا الحقل مطلوب.';
      if (field.validity.typeMismatch && field.type === 'email') {
        msg = 'يرجى إدخال بريد إلكتروني صحيح.';
      }
      errorEl.textContent = msg;
      field.setAttribute('aria-invalid', 'true');
      field.setAttribute('aria-describedby', `${field.id}-error`);
      return false;
    }

    clearFieldError(field);
    return true;
  }

  function clearFieldError(field: HTMLInputElement | HTMLTextAreaElement) {
    const errorEl = document.getElementById(`${field.id}-error`);
    if (errorEl) errorEl.textContent = '';
    field.removeAttribute('aria-invalid');
    field.removeAttribute('aria-describedby');
  }
</script>

<style>
  .contact-page {
  }

  .background__grid {
    display: none;
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--color-primary-10) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-primary-10) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(ellipse 60% 70% at 50% 50%, black 0%, transparent 85%);
    -webkit-mask-image: radial-gradient(ellipse 60% 70% at 50% 50%, black 0%, transparent 85%);
  }

  /* Desktop locked 100vh layout */
  @media (min-width: 768px) {
    .contact-page.is-locked {
      height: 100dvh;
      overflow: hidden;
    }

    .contact-page.is-locked .contact__content {
      flex-grow: 1;
      display: flex;
      align-items: stretch;
      overflow: hidden;
      padding: 0;
      min-height: 0;
    }
  }

  .contact__content {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .contact__body {
    display: grid;
    grid-template-columns: 1fr 1fr; /* 2 equal columns */
    gap: var(--space-4);
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    height: 100%;
    min-height: 0;
    align-items: stretch;
    padding-top: var(--space-2);
    padding-bottom: var(--space-2);
  }

  .contact__col {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 0;
  }

  .contact__headline-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-2);
  }

  .contact__headline {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 3.5vw, 3.5rem);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    line-height: var(--leading-snug);
    text-align: start;
  }

  .contact__subtext {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    max-width: 90%;
    text-align: start;
    margin-bottom: var(--space-3);
  }

  .contact__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  .contact__info-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start; /* Forces LTR contents to align to flex-start (Right in RTL) */
    gap: 4px;
  }

  .contact__info-header {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--color-primary);
  }

  .contact__info-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .contact__info-link {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-text-primary);
    font-weight: var(--weight-medium);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-smooth);
  }

  .contact__info-link:hover {
    color: var(--color-primary-60);
  }

  .contact__form-panel {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .contact__honeypot {
    display: none;
  }

  /* ARIA status messages */
  .contact__status {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    border-radius: var(--radius-md);
    min-height: 0;
    transition: all var(--duration-fast) var(--ease-smooth);
  }

  .contact__status:not(:empty) {
    padding: 10px var(--space-2);
    margin-bottom: var(--space-1);
  }

  .contact__status--pending {
    color: var(--color-text-secondary);
    background: var(--color-primary-10);
  }

  .contact__status--success {
    color: var(--color-text-primary);
    background: var(--color-primary-10);
    border: 1px solid var(--color-primary-20);
  }

  .contact__status--error {
    color: var(--color-text-primary);
    background: rgba(180, 60, 40, 0.08);
    border: 1px solid rgba(180, 60, 40, 0.2);
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .contact__form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2);
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .contact__label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
  }

  .contact__error {
    font-family: var(--font-sans);
    font-size: 11px;
    color: #8b2010;
    min-height: 14px;
    margin-top: -2px;
  }

  .contact__input {
    padding: 12px 14px;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.4);
    border: 1px solid var(--color-glass-border);
    border-radius: var(--radius-md);
    width: 100%;
    transition: all var(--duration-fast) var(--ease-smooth);
    min-block-size: 44px;
  }

  .contact__input::placeholder {
    color: var(--color-text-secondary);
    opacity: 0.5;
  }

  .contact__input:focus-visible {
    border-color: var(--color-primary-60);
    box-shadow: 0 0 0 3px var(--color-primary-10);
    outline: none;
  }

  .contact__input[aria-invalid='true'] {
    border-color: #8b2010;
  }

  .contact__textarea {
    resize: none;
    min-height: 60px;
    flex-grow: 1; /* Allow textarea to grow slightly if space permits */
  }

  .contact__submit {
    padding: 12px var(--space-3);
    min-block-size: 44px;
    width: 100%;
    background-color: var(--color-primary);
    color: var(--color-background);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-smooth);
    margin-top: var(--space-1);
  }

  .contact__submit:hover:not(:disabled) {
    background-color: var(--color-text-primary);
    transform: translateY(-1px);
  }

  .contact__submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  @media (max-width: 1199px) {
    .contact__body {
      gap: var(--space-4);
    }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .contact__body {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
      padding: var(--space-2) 0;
    }

    .contact__form-row {
      grid-template-columns: 1fr;
    }

    .contact__subtext {
      max-width: none;
    }
  }

  /* Short screens — reduce density so form fits without scrolling */
  @media (max-height: 600px) {
    .contact__body {
      gap: var(--space-1);
      padding: var(--space-1) 0;
    }

    .contact__form {
      gap: var(--space-1);
    }

    .contact__textarea {
      min-height: 52px;
    }
  }

  @media (max-height: 500px) {
    .contact__headline-block {
      display: none;
    }

    .contact__form-panel {
      flex: unset;
      width: 100%;
      max-width: 480px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact__input,
    .contact__submit,
    .contact__status {
      transition: none;
    }
  }
</style>
