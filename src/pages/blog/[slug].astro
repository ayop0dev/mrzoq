---
/**
 * Blog Post - Marzoq Content Page
 *
 * Content Pages intentionally support vertical scrolling.
 * Long-form educational content. Reading should feel comfortable and uninterrupted.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getAllPublishedPosts, getPostBySlug } from '../../lib/wordpress.js';

export async function getStaticPaths() {
  const posts = await getAllPublishedPosts();
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { slug } = Astro.params;
const { post: propPost } = Astro.props;

const post = propPost ?? (await getPostBySlug(slug));

if (!post) {
  return Astro.redirect('/blog', 302);
}

function formatDate(dateString) {
  return new Date(dateString).toLocaleDateString('ar-SA', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const publishDate = formatDate(post.date);
const modifiedIsRelevant =
  post.modified && new Date(post.modified).getTime() - new Date(post.date).getTime() > 60 * 1000;
const modifiedDate = modifiedIsRelevant ? formatDate(post.modified) : null;
const taxonomy = post.categories.length > 0 ? post.categories : post.tags;
const articleTags = [...post.categories, ...post.tags].map((term) => term.name);
const description = post.excerpt || 'مقال من مدونة مرزوق حول الذكاء الاصطناعي والحضور الرقمي.';
const title = `${post.title} | مرزوق`;
const ogImage = post.featuredImage?.url;

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description,
  inLanguage: 'ar',
  url: post.canonical,
  mainEntityOfPage: post.canonical,
  datePublished: post.date,
  dateModified: post.modified || post.date,
  author: post.author
    ? {
        '@type': 'Person',
        name: post.author.name,
      }
    : {
        '@type': 'Organization',
        name: 'Marzoq',
      },
  publisher: {
    '@type': 'Organization',
    name: 'Marzoq',
  },
  ...(ogImage ? { image: ogImage } : {}),
  ...(post.categories.length
    ? { articleSection: post.categories.map((category) => category.name) }
    : {}),
  ...(post.tags.length ? { keywords: post.tags.map((tag) => tag.name).join(', ') } : {}),
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={post.canonical}
  ogImage={ogImage}
  type="article"
  article={{
    publishedTime: post.date,
    modifiedTime: modifiedIsRelevant ? post.modified : undefined,
    author: post.author?.name,
    tags: articleTags,
  }}
  jsonLd={blogPostingSchema}
>
  <div class="page-content blog-post">
    <Header currentPath="/blog" hideCta={true} />

    <main id="main-content">
      <article class="content-container blog-post__article">
        <header class="blog-post__article-header">
          <div class="blog-post__meta">
            <time class="blog-post__date" datetime={post.date}>{publishDate}</time>
            {modifiedDate && <span class="blog-post__modified">تحديث: {modifiedDate}</span>}
            {post.author && <span class="blog-post__author">{post.author.name}</span>}
          </div>

          <h1 class="blog-post__title">{post.title}</h1>

          {description && <p class="blog-post__excerpt">{description}</p>}

          {
            taxonomy.length > 0 && (
              <ul class="blog-post__terms" aria-label="تصنيفات المقال">
                {taxonomy.map((term) => (
                  <li>{term.name}</li>
                ))}
              </ul>
            )
          }
        </header>

        {
          post.featuredImage && (
            <figure class="blog-post__featured">
              <img
                src={post.featuredImage.url}
                alt={post.featuredImage.alt}
                width={post.featuredImage.width}
                height={post.featuredImage.height}
                loading="eager"
                decoding="async"
              />
            </figure>
          )
        }

        <div class="blog-post__body prose" set:html={post.content} />

        <div class="blog-post__back-wrapper">
          <a href="/blog" class="blog-post__back focus-visible">العودة إلى المدونة</a>
        </div>
      </article>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
  .blog-post {
    background-color: transparent;
  }

  .blog-post__header {
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-glass-border);
    position: sticky;
    top: 0;
    background: var(--color-background-warm);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: var(--z-header);
  }

  .blog-post__article {
    padding-top: var(--space-8);
    padding-bottom: var(--space-12);
  }

  .blog-post__article-header {
    margin-bottom: var(--space-5);
  }

  .blog-post__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-2);
    align-items: center;
    margin-bottom: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .blog-post__date,
  .blog-post__modified,
  .blog-post__author {
    display: inline-flex;
    align-items: center;
  }

  .blog-post__title {
    font-family: var(--font-sans);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-snug);
    color: var(--color-primary);
  }

  .blog-post__excerpt {
    max-width: 760px;
    margin-top: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
  }

  .blog-post__terms {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: var(--space-2);
    list-style: none;
  }

  .blog-post__terms li {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-glass-border);
    border-radius: var(--radius-full);
    padding: 4px 10px;
  }

  .blog-post__featured {
    margin-bottom: var(--space-5);
  }

  .blog-post__featured img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-glass-border);
  }

  /* Long-form prose styles */
  .prose {
    font-family: var(--font-text);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-primary);
  }

  .prose :global(h2) {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
  }

  .prose :global(h3),
  .prose :global(h4),
  .prose :global(h5),
  .prose :global(h6) {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    margin-top: var(--space-4);
    margin-bottom: var(--space-1);
  }

  .prose :global(p),
  .prose :global(figure),
  .prose :global(table),
  .prose :global(blockquote),
  .prose :global(pre) {
    margin-bottom: var(--space-3);
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-inline-start: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .prose :global(li) {
    margin-bottom: var(--space-1);
  }

  .prose :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(a:focus-visible) {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  .prose :global(img),
  .prose :global(video),
  .prose :global(iframe) {
    max-width: 100%;
  }

  .prose :global(img) {
    height: auto;
    border-radius: var(--radius-md);
  }

  .prose :global(figure) {
    max-width: 100%;
  }

  .prose :global(figcaption),
  .prose :global(.wp-element-caption) {
    margin-top: var(--space-1);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .prose :global(blockquote) {
    border-inline-start: 1px solid var(--color-primary-40);
    padding-inline-start: var(--space-3);
    color: var(--color-text-secondary);
    margin: var(--space-4) 0;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
  }

  .prose :global(th),
  .prose :global(td) {
    border: 1px solid var(--color-glass-border);
    padding: var(--space-1);
    text-align: start;
    vertical-align: top;
  }

  .prose :global(.wp-block-embed__wrapper) {
    position: relative;
    max-width: 100%;
    overflow: hidden;
  }

  .blog-post__back-wrapper {
    margin-top: var(--space-8);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-glass-border);
  }

  .blog-post__back {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    min-block-size: 44px;
    transition: color var(--duration-fast) var(--ease-smooth);
  }

  .blog-post__back:hover {
    color: var(--color-text-primary);
  }

  @media (max-width: 767px) {
    .blog-post__article {
      padding-top: var(--space-4);
    }

    .blog-post__title {
      font-size: var(--text-xl);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-post__back {
      transition: none;
    }
  }
</style>
