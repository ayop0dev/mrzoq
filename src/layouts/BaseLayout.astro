---
/**
 * BaseLayout — shared HTML shell for every page.
 * Provides: global styles, canonical URL, Open Graph, structured data, font preloads.
 */
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  dir?: 'rtl' | 'ltr';
  canonical?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    tags?: string[];
  };
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'مرزوق — Marzoq',
  description = 'مرزوق يساعد الشركات على أن تكون الإجابة التي يقدمها الذكاء الاصطناعي.',
  lang = 'ar',
  dir = 'rtl',
  type = 'website',
  article,
  jsonLd,
} = Astro.props;

const siteUrl = import.meta.env.SITE_URL || 'https://mrzoq.com';
const canonical = Astro.props.canonical || `${siteUrl}${Astro.url.pathname}`;
const ogImage = Astro.props.ogImage || `${siteUrl}/og-default.png`;
const cmsUrl = import.meta.env.WORDPRESS_URL || '';

// Organization Schema.org structured data
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Marzoq',
  alternateName: 'مرزوق',
  url: siteUrl,
  description:
    'Marzoq helps businesses become discoverable, understandable, and recommendable by AI systems.',
  knowsAbout: [
    'AI Discoverability',
    'Digital Presence Optimization',
    'Branding',
    'Web Development',
    'Content Strategy',
  ],
};

const structuredData = [
  organizationSchema,
  ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []),
];
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="مرزوق — Marzoq" />
    <meta property="og:locale" content="ar_SA" />
    {
      type === 'article' && article?.publishedTime && (
        <meta property="article:published_time" content={article.publishedTime} />
      )
    }
    {
      type === 'article' && article?.modifiedTime && (
        <meta property="article:modified_time" content={article.modifiedTime} />
      )
    }
    {
      type === 'article' && article?.author && (
        <meta property="article:author" content={article.author} />
      )
    }
    {
      type === 'article' &&
        article?.tags?.map((tag) => <meta property="article:tag" content={tag} />)
    }

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Performance: early connection to CMS for pages that fetch dynamic content -->
    {cmsUrl && <link rel="dns-prefetch" href={cmsUrl} />}
    {cmsUrl && <link rel="preconnect" href={cmsUrl} crossorigin />}

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap.xml" />

    <!-- Preload critical fonts -->
    <link
      rel="preload"
      href="/fonts/thmanyahsans/thmanyahsans-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/thmanyahsans/thmanyahsans-Medium.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
