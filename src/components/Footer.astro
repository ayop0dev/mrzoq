---
/**
 * Footer — shared site footer.
 * Copyright year is computed at build time so it never goes stale.
 */
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer__inner">
    <div class="footer__socials">
      <a href="#" aria-label="إنستجرام" class="footer__social-link focus-visible">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
      </a>
      <a href="#" aria-label="تيك توك" class="footer__social-link focus-visible">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
      </a>
      <a href="#" aria-label="فيسبوك" class="footer__social-link focus-visible">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
      </a>
      <a href="#" aria-label="يوتيوب" class="footer__social-link focus-visible">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
      </a>
    </div>
    <nav aria-label="روابط ثانوية" class="footer__nav">
      <a href="/privacy" class="footer__link focus-visible">الخصوصية</a>
      <span class="footer__dot">•</span>
      <a href="/terms" class="footer__link focus-visible">الشروط</a>
      <span class="footer__dot">•</span>
      <p class="footer__copyright">
        <small>© {year} مرزوق. جميع الحقوق محفوظة.</small>
      </p>
    </nav>
  </div>
</footer>

<style>
  .footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between; /* Elements at the extreme edges */
    gap: var(--space-6);
    flex-wrap: wrap; 
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0; /* No left/right padding */
  }

  .footer__copyright small {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .footer__socials {
    display: flex;
    gap: var(--space-3);
    align-items: center;
  }

  .footer__social-link {
    color: var(--color-text-secondary);
    opacity: 0.5;
    transition: color var(--duration-fast) var(--ease-smooth), transform var(--duration-fast) var(--ease-smooth), opacity var(--duration-fast) var(--ease-smooth);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer__social-link:hover,
  .footer__social-link:active {
    color: var(--color-text-primary);
    transform: translateY(-2px);
    opacity: 1;
  }

  .footer__nav {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    justify-content: center; /* Changed from flex-end */
  }

  .footer__dot {
    color: var(--color-primary-40);
    font-size: var(--text-xs);
    opacity: 0.5;
    transition: opacity var(--duration-fast) var(--ease-smooth);
  }

  .footer__link {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    text-decoration: none;
    opacity: 0.5;
    transition: color var(--duration-fast) var(--ease-smooth), opacity var(--duration-fast) var(--ease-smooth);
    display: inline-flex;
    align-items: center;
    min-block-size: 44px;
  }

  .footer__link:hover,
  .footer__link:active {
    color: var(--color-text-primary);
    opacity: 1;
  }

  .footer__copyright {
    display: inline-flex;
    align-items: center;
    margin: 0;
    opacity: 0.5;
    transition: opacity var(--duration-fast) var(--ease-smooth);
  }

  .footer__copyright:hover,
  .footer__copyright:active {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .footer__link {
      transition: none;
    }
  }

  @media (max-width: 767px) {
    .footer__inner {
      flex-direction: column;
      gap: var(--space-3);
      justify-content: center;
    }
    
    /* Removed .footer__socials { display: none; } so they show on mobile too */

    .footer__nav {
      justify-content: center;
      text-align: center;
      gap: 6px;
      flex-wrap: nowrap;
    }

    .footer__link,
    .footer__dot,
    .footer__copyright small {
      font-size: 10px;
    }

    .footer__link {
      min-block-size: 32px;
    }
    
    .footer__copyright {
      justify-content: center;
      margin-top: 0;
      white-space: nowrap;
    }
  }
</style>
